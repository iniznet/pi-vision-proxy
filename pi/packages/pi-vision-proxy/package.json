{
  "name": "pi-vision-proxy",
  "version": "1.4.0-beta.1",
  "description": "Automatic image description for non-vision models in Pi. Routes images to a vision model and injects descriptions into context.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "node --experimental-strip-types --no-warnings --test extensions/__tests__/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./extensions/vision-proxy.ts"
    ]
  },
  "dependencies": {
    "image-size": "^2.0.2"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "typebox": "*"
  }
}
